    .mipi_dp_data3_LP_P_OUT(mipi_tx_dp13_LP_P_OUT),

	  .mipi_dp_data0_RST   (mipi_tx_dp10_RST),
	  .mipi_dp_data1_RST   (mipi_tx_dp11_RST),
	  .mipi_dp_data2_RST   (mipi_tx_dp12_RST),
    .mipi_dp_data3_RST     (mipi_tx_dp13_RST)
  );


//================================================================================== 
//hdmi_top
//==================================================================================
  `ifdef  HDMI_OUT_EN  
   reg sel = 1'b0;
  reg rgb_vs_r;
  reg rgb_hs_r;
  reg rgb_de_r;
  reg [23:0] rgb_datax1;

// 测试图案生成器 - 用于验证HDMI输出
reg [11:0] test_h_cnt;
reg [11:0] test_v_cnt;
reg test_hs, test_vs, test_de;
reg [23:0] test_rgb;

always @(posedge hdmi_tx_slow_clk or negedge sys_rst_n) begin
    if(!sys_rst_n) begin
        test_h_cnt <= 0;
        test_v_cnt <= 0;
        test_hs <= 0;
        test_vs <= 0;
        test_de <= 0;
    end else begin
        // 640x480@60Hz时序 (25.175MHz像素时钟)
        // H: 640 + 16(FP) + 96(SYNC) + 48(BP) = 800 total
        // V: 480 + 10(FP) + 2(SYNC) + 33(BP) = 525 total
        if(test_h_cnt < 799) begin
            test_h_cnt <= test_h_cnt + 1;
        end else begin
            test_h_cnt <= 0;
            if(test_v_cnt < 524) begin
                test_v_cnt <= test_v_cnt + 1;
            end else begin
                test_v_cnt <= 0;
            end
        end
        
        // HS: 96 pixels (sync pulse, negative polarity)
        test_hs <= ~(test_h_cnt >= 640+16 && test_h_cnt < 640+16+96);
        // VS: 2 lines (sync pulse, negative polarity)
        test_vs <= ~(test_v_cnt >= 480+10 && test_v_cnt < 480+10+2);
        // DE: active area (640x480)
        test_de <= (test_h_cnt < 640) && (test_v_cnt < 480);
    end
end

// 彩条图案 (7色彩条)
always @(posedge hdmi_tx_slow_clk) begin
    if(test_de) begin
        if(test_h_cnt < 91)           // 640/7 ≈ 91
            test_rgb <= 24'hFFFFFF; // 白色
        else if(test_h_cnt < 182)
            test_rgb <= 24'hFFFF00; // 黄色
        else if(test_h_cnt < 273)
            test_rgb <= 24'h00FFFF; // 青色
        else if(test_h_cnt < 364)
            test_rgb <= 24'h00FF00; // 绿色
        else if(test_h_cnt < 455)
            test_rgb <= 24'hFF00FF; // 品红
        else if(test_h_cnt < 546)
            test_rgb <= 24'hFF0000; // 红色
        else
            test_rgb <= 24'h0000FF; // 蓝色
    end else begin
        test_rgb <= 24'h000000; // 黑色
    end
end

// HDMI强制输出彩条测试图案
// MIPI屏幕输出摄像头画面（在dsi_top模块中）
wire use_test_pattern = 1'b1; // 强制使用测试图案（彩条）

always @( posedge hdmi_tx_slow_clk )
begin
    sel <= ~sel;
end

always @( posedge hdmi_tx_slow_clk )
begin
    // HDMI始终使用彩条测试图案
    rgb_vs_r <= test_vs;
    rgb_hs_r <= test_hs;
    rgb_de_r <= test_de;
    rgb_datax1 <= test_rgb;
end
  hdmi_top  hdmi_top_inst (
    .hdmi_tx_locked(hdmi_pll_locked),
    .i_hs(rgb_hs_r),
    .i_vs(rgb_vs_r),
    .i_de(rgb_de_r),
    .i_rdata(rgb_datax1[23:16]),
    .i_gdata(rgb_datax1[15:8]),
    .i_bdata(rgb_datax1[7:0]), 
    .hdmi_tx_slow_clk(hdmi_tx_slow_clk),
    .tmds_data0_o(tmds_data0_TX_DATA),
    .tmds_data1_o(tmds_data1_TX_DATA),
    .tmds_data2_o(tmds_data2_TX_DATA),
    .tmds_clk_o(tmds_clk_TX_DATA),
    .tmds_data0_TX_OE(tmds_data0_TX_OE),
    .tmds_data1_TX_OE(tmds_data1_TX_OE),
    .tmds_data2_TX_OE(tmds_data2_TX_OE),
    .tmds_clk_TX_OE(tmds_clk_TX_OE),
    .tmds_data0_TX_RST(tmds_data0_TX_RST),
    .tmds_data1_TX_RST(tmds_data1_TX_RST),
    .tmds_data2_TX_RST(tmds_data2_TX_RST),
    .tmds_clk_TX_RST(tmds_clk_TX_RST)
  );
`endif 
endmodule
