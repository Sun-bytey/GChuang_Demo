    .mipi_dp_clk_RST     (mipi_tx_ck1_RST),

    .mipi_dp_data0_LP_N_IN(mipi_tx_dp10_LP_N_IN),
    .mipi_dp_data0_LP_P_IN(mipi_tx_dp10_LP_P_IN),

    .mipi_dp_data0_HS_OE   (mipi_tx_dp10_HS_OE),
